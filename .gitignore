# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/

# OS
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# Claude Code per-user settings (settings.json is committed; .local.json is not)
.claude/settings.local.json

# Tool state (regenerable; do not commit session/handoff state)
.serena/
.remember/

# Runtime data caches (the data/ directory is tracked via .gitkeep)
data/*.db
data/*.sqlite
data/*.sqlite3
data/*.db-journal

# Environment / secrets
.env
.env.*
!.env.example

# External reference repo (separately maintained, cloned alongside if needed)
faceoff/

# Temporary migration scratch (created/deleted within a single iteration)
.migration-scratch/
